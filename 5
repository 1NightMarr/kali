#!/bin/bash

# Перевірка аргументів
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <input_file> <output_file>"
    exit 1
fi

INPUT_FILE=$1
OUTPUT_FILE=$2

# Перевірка, чи існує вхідний файл
if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File $INPUT_FILE not found!"
    exit 1
fi

# Рахуємо кількість рядків для прогрес-бару
TOTAL_LINES=$(wc -l < "$INPUT_FILE")
CURRENT=0

# Очищуємо файл виводу перед стартом
> "$OUTPUT_FILE"

echo "Resolving $TOTAL_LINES hosts from $INPUT_FILE to $OUTPUT_FILE..."
echo "Press Ctrl+C to stop."

while read -r host_name; do
    ((CURRENT++))
    
    # Резолвінг через системний 'host'
    # head -n 1 беремо на випадок, якщо у хоста кілька IP
    IP=$(host "$host_name" | grep "has address" | awk '{print $4}' | head -n 1)
    
    if [ -n "$IP" ]; then
        # Записуємо у файл у форматі: Hostname IP
        echo -e "${host_name}\t${IP}" >> "$OUTPUT_FILE"
    fi

    # Малюємо прогрес-бар
    PERCENT=$(( CURRENT * 100 / TOTAL_LINES ))
    # Створюємо візуальну смужку (довжина 40 символів)
    BAR_SIZE=$(( PERCENT * 40 / 100 ))
    printf -v BAR "%${BAR_SIZE}s" ""
    printf -v SPACE "%$((40 - BAR_SIZE))s" ""
    printf "\rProgress: [%s%s] %d%% (%d/%d)" "${BAR// /#}" "${SPACE// /-}" "$PERCENT" "$CURRENT" "$TOTAL_LINES"

    # Stealth Jitter: випадкова пауза від 3 до 7 секунд
    # Це важливо, щоб не спалитись перед EDR/IDS
    if [ "$CURRENT" -lt "$TOTAL_LINES" ]; then
        sleep $(( ( RANDOM % 5 ) + 3 ))
    fi

done < "$INPUT_FILE"

echo -e "\n\nDone! Results saved to $OUTPUT_FILE"
